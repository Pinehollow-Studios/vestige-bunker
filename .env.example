# ── Supabase connection (dev/prod env switch) ───────────────────────────
# The dashboard reads/writes against ONE project at a time, chosen at
# runtime by the `vestige_admin_env` cookie (TopBar dev/prod toggle).
# Editorial is authored on dev; live TestFlight user data lives on prod.
#
#   Dev:  Vestige-iOS-Dev   (ref lztggqifpzpnjwqwigks)
#   Prod: vestige-ios-prod  (ref ujbnupjrbroskzwaeulj)
#
# Anon keys are public + RLS-gated (they ship in the iOS binary), so both
# envs' anon keys are safe as NEXT_PUBLIC. Set the _DEV / _PROD pairs to
# enable the switch; the legacy unsuffixed vars below are the dev fallback
# (kept working for any pre-switch setup).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

NEXT_PUBLIC_SUPABASE_URL_DEV=
NEXT_PUBLIC_SUPABASE_ANON_KEY_DEV=
NEXT_PUBLIC_SUPABASE_URL_PROD=
NEXT_PUBLIC_SUPABASE_ANON_KEY_PROD=

# ── Editorial sync (dev→prod mirror, /sync — super_admin only) ───────────
# SERVER-ONLY service-role keys (never NEXT_PUBLIC, never committed). The
# mirror reads dev + writes prod via these, bypassing RLS. Grab each from
# the project's Supabase dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY_DEV=
SUPABASE_SERVICE_ROLE_KEY_PROD=

# Origin used to build magic-link redirect URLs. http://localhost:3000 in dev,
# the deployed origin (e.g. https://admin.vestige.app) in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry Web API access — drives the lazy stack-trace + breadcrumbs
# pull on /crashes/[id]. All three must be set together; with any
# missing the detail page renders a "Sentry not configured" inline
# placeholder and the local crash row is the only data shown. The
# crashes queue itself works without these — it reads from the
# `crash_reports` table populated by the `sentry-webhook` Edge
# Function. See `Vestige-ios/docs/sentry-setup.md`.
#
# SENTRY_AUTH_TOKEN  — Internal Integration auth token. Mint at
#                      sentry.io → pinehollow-studios → Settings →
#                      Developer Settings → vestige-admin → Tokens.
#                      Permissions: Project: Read, Issue & Event:
#                      Read, Member: Read.
# SENTRY_ORG_SLUG    — `pinehollow-studios`.
# SENTRY_PROJECT_SLUG — `vestige-ios`.
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=pinehollow-studios
SENTRY_PROJECT_SLUG=vestige-ios

# Hidden developer-only env switch. When "true", a toggle appears to point the
# dashboard (data + auth) at dev for testing. Set in local + Vercel Preview
# ONLY — never in Vercel Production (the live dashboard is prod-only).
NEXT_PUBLIC_ENABLE_DEV_SWITCH=true
